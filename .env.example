# ============================================================
# HaBayit — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored by default in Next.js — never commit real keys.
# ============================================================

# --- Supabase ---
# Found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (TEST MODE keys only for now) ---
# Found in Stripe Dashboard > Developers > API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret (set up once we wire webhooks in a later phase)
STRIPE_WEBHOOK_SECRET=

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_CONTACT_ID=
GOOGLE_SHEETS_DONATIONS_ID=
GOOGLE_SHEETS_CHAI_PARTNERS_ID=
GOOGLE_SHEETS_HEBREW_SCHOOL_ID=
GOOGLE_SHEETS_ACHIM_ID=
GOOGLE_SHEETS_BLOOM_ID=

# --- Resend ---
# Found in Resend Dashboard > API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@habayitcc.org
